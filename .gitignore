# .gitignore — Overage project
# Comprehensive ignores for Python, tools, IDE, OS, and project-specific files.

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyo
*.pyd

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
ENV/
env/

# Pip cache colocated on slow/usb volumes (optional: export PIP_CACHE_DIR=.pip-cache)
.pip-cache/

# =============================================================================
# Testing & Coverage
# =============================================================================
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# =============================================================================
# Linting & Type Checking
# =============================================================================
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# =============================================================================
# Secrets & Environment
# =============================================================================
.env
.env.local
.env.production
.env.staging
# .secrets.baseline is committed (needed by detect-secrets pre-commit hook)

# =============================================================================
# Database (local dev)
# =============================================================================
*.sqlite
*.sqlite3
*.db
overage_dev.db
test.db

# =============================================================================
# ML Model Weights (too large for git — use Git LFS or external storage)
# =============================================================================
*.bin
*.safetensors
*.pt
*.pth
*.onnx
*.gguf
models/

# Model evaluation results (regenerated by CI)
model/eval/results/*.json

# =============================================================================
# IDE & Editors
# =============================================================================
# VS Code — keep settings.json and extensions.json, ignore everything else
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# JetBrains (PyCharm)
.idea/

# Vim
*.swp
*.swo
*~

# Emacs
\#*\#
.\#*

# =============================================================================
# OS Files
# =============================================================================
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# =============================================================================
# Docker
# =============================================================================
# Don't ignore docker-compose.yml or Dockerfile (they should be committed)
# But ignore docker data volumes
docker-data/

# =============================================================================
# Node.js (if landing page or Next.js dashboard uses Node)
# =============================================================================
node_modules/
.next/
out/
.vercel/
package-lock.json
yarn.lock

# =============================================================================
# Miscellaneous
# =============================================================================
# Jupyter notebooks (checkpoints)
.ipynb_checkpoints/

# Log files
*.log
logs/

# Temporary files
tmp/
temp/

# Profiling output
*.prof
profile_results/
