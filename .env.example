# .env.example — Environment variable template for Overage
# Copy to .env and fill in your values: cp .env.example .env
# NEVER commit the actual .env file (it's in .gitignore).
# Reference: INSTRUCTIONS.md Section 14 (Environment Variables)

# =============================================================================
# Application
# =============================================================================
OVERAGE_ENV=development          # development | staging | production
DEBUG=true                       # Enable debug mode (required: no, default: false)
LOG_LEVEL=DEBUG                  # DEBUG | INFO | WARNING | ERROR (default: INFO)
PROXY_HOST=0.0.0.0              # Bind host (default: 0.0.0.0)
PROXY_PORT=8000                  # Bind port (default: 8000)

# =============================================================================
# Database
# =============================================================================
# Local dev (SQLite — zero config):
DATABASE_URL=sqlite+aiosqlite:///./overage_dev.db

# Docker Compose (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://overage:overage_dev@localhost:5432/overage

# Production (Supabase):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/overage

# =============================================================================
# LLM Provider API Keys (for proxying — at least one required for live traffic)
# =============================================================================
OPENAI_API_KEY=                  # sk-... (optional, required for OpenAI proxying)
ANTHROPIC_API_KEY=               # sk-ant-... (optional, required for Anthropic proxying)
GEMINI_API_KEY=                  # AIza... (optional, required for Gemini proxying)

# =============================================================================
# Security
# =============================================================================
API_KEY_SECRET=dev-secret-change-me-in-production  # Secret for hashing API keys (required in prod)
RATE_LIMIT_PER_MINUTE=100        # Max requests per API key per minute (default: 100)
CORS_ORIGINS=http://localhost:8501  # Comma-separated allowed CORS origins

# =============================================================================
# Estimation Model (PALACE)
# =============================================================================
ESTIMATION_ENABLED=true          # Enable async estimation pipeline (default: true)
PALACE_MODEL_PATH=./models/palace-v0.1  # Path to PALACE LoRA weights
PALACE_MODEL_VERSION=v0.1.0     # Model version tag (recorded with every estimation)

# =============================================================================
# Monitoring & Observability
# =============================================================================
SENTRY_DSN=                      # Sentry error tracking DSN (optional)
SENTRY_TRACES_SAMPLE_RATE=0.1   # % of transactions to trace (default: 0.1 = 10%)
DATADOG_API_KEY=                 # Datadog APM key (optional)
POSTHOG_API_KEY=                 # PostHog product analytics key (optional)

# =============================================================================
# External Services
# =============================================================================
DISCORD_WEBHOOK_URL=             # Discord webhook for deploy notifications (optional)
