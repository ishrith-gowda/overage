# .env.example — Environment variable template for Overage
# Copy to .env and fill in your values: cp .env.example .env
# NEVER commit the actual .env file (it's in .gitignore).
# Reference: INSTRUCTIONS.md Section 14 (Environment Variables)

# =============================================================================
# Application
# =============================================================================
OVERAGE_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG

# =============================================================================
# Database
# =============================================================================
# Local dev (SQLite — zero config):
DATABASE_URL=sqlite+aiosqlite:///./overage_dev.db
# Docker Compose (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://overage:overage_dev@localhost:5432/overage

# =============================================================================
# LLM Provider API Keys (at least one required for live traffic)
# =============================================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# =============================================================================
# Security
# =============================================================================
API_KEY_SECRET=dev-secret-change-me-in-production
RATE_LIMIT_PER_MINUTE=100
CORS_ORIGINS=http://localhost:8501

# =============================================================================
# Estimation Model (PALACE)
# =============================================================================
ESTIMATION_ENABLED=false
PALACE_MODEL_PATH=./models/palace-v0.1
PALACE_MODEL_VERSION=v0.1.0

# =============================================================================
# Monitoring (all optional)
# =============================================================================
SENTRY_DSN=
POSTHOG_API_KEY=
